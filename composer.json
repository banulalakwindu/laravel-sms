{
    "name": "banulakwin/laravel-sms",
    "description": "Portable Laravel SMS package with multi-provider driver architecture.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "sms", "textlk", "messaging", "gateway"],
    "homepage": "https://github.com/banulalakwindu/laravel-sms",
    "support": {
        "issues": "https://github.com/banulalakwindu/laravel-sms/issues",
        "source": "https://github.com/banulalakwindu/laravel-sms"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "textlk/textlk-php": "^2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Banulakwin\\Sms\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Banulakwin\\Sms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Banulakwin\\Sms\\SmsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "pint": "pint",
        "pint:check": "pint --test",
        "phpstan": "phpstan analyse",
        "analyse": "@phpstan",
        "quality": ["@pint", "@phpstan", "@test"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
